---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean; // 将来の下書き・限定公開ページ用
}

const {
  title,
  description = '受託開発会社 Promethix LLC — Webアプリ・業務システムの設計から運用までワンストップで支援します。',
  ogImage = '/og.png',
  jsonLd,
  noindex = false,
} = Astro.props;

const SITE_NAME = 'Promethix LLC';
// title が会社名と一致するトップページでは「Promethix LLC | Promethix LLC」の重複を避ける
const pageTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
// site 未設定でもビルドが落ちないようフォールバック
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
// OGP/Twitter 画像は絶対URL必須。canonical と同じ Astro.site パターンで絶対化
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />

    <!-- 自己ホストフォント（astro:fonts / Fonts API）。preload で h1 のウェイトを早期取得し LCP を前倒し -->
    <Font cssVariable="--font-inter" preload />

    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Promethix LLC" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{pageTitle}</title>

    <!-- 構造化データ（schema.org JSON-LD）。会社情報の二重管理を避けるため各ページから Props で受け取る -->
    {jsonLd && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">本文へスキップ</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-text);
        color: var(--color-text-invert);
        padding: 12px 18px;
        z-index: 100;
      }
      .skip-link:focus { left: 16px; top: 16px; }
    </style>
  </body>
</html>
