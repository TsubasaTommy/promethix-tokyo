---
import Base from '../layouts/Base.astro';

const strengths = [
  {
    no: '01',
    title: '自社プロダクトで磨かれた設計力',
    body: '私たちは受託だけでなく、自分たちでもサービスを企画・開発・運用している現役チームです。要件に最適な技術スタックで、長く運用に耐えるアーキテクチャを組みます。',
  },
  {
    no: '02',
    title: '最新AIを開発プロセスに活用',
    body: '設計レビュー・コード生成・テスト・ドキュメント整備など、開発フローのあらゆる工程に生成AIを組み込んでいます。従来と比べて品質と速度を同時に引き上げ、プロダクトをより確実にお届けします。',
  },
  {
    no: '03',
    title: '長く使える品質を最優先',
    body: '「動くシステム」ではなく「長く安心して使えるシステム」を最重要視しています。テスト自動化・コードレビュー・継続的なリファクタリングを徹底し、リリース後の運用で苦労しない実装を行います。',
  },
];

const services = [
  {
    icon: '◈',
    title: 'Webアプリ開発, API構築',
    body: 'マイクロサービス・SaaS・社内ツール・LPまで、要件に合わせた最適なスタックで構築します。自社プロダクトで磨いた設計力をそのまま提供します。',
    tags: ['GCP', 'Go', 'PHP', 'Echo', 'Laravel', 'Laravel Octane (FrankenPHP)' ,'gRPC', 'Mysql', 'Postgre', 'BigQuery' ],
  },
  {
    icon: '◉',
    title: '業務システム開発',
    body: '請求・記録・スケジューリングなど、複雑な業務プロセスを長期運用に耐える設計でシステム化します。要件整理から実装・運用までワンストップ。',
    tags: ['GCP', 'Go', 'PHP', 'Echo', 'Laravel', 'Laravel Octane (FrankenPHP)' ,'gRPC', 'Mysql', 'Postgre', 'BigQuery' ],
  },
  {
    icon: '◎',
    title: '運用・保守',
    body: 'リリース後の改善・保守運用を月額契約で安定して継続できます。システムやDBのパフォーマンス改善もお任せください。',
    tags: ['GCP', 'Go', 'PHP', 'Postgre', 'Mysql' ],
  },
];

const works = [
  {
    icon: '◈',
    category: 'Webアプリ・SaaS',
    intro: 'エンドユーザー向けの大規模Webサービスを、設計から継続運用まで。',
    items: [
      {
        name: '総合業務支援システム（基幹）',
        desc: '継続稼働中・数百Issue規模をモノレポで継続開発する基幹システム。',
        tech: ['PHP / Laravel', 'Nuxt (Vue)', 'TypeScript', 'AWS (ECS / Aurora / CloudFront)', 'OpenAPI (TypeSpec)'],
      },
      {
        name: '事業者向けマッチングプラットフォーム（SaaS）',
        desc: 'フロント / API / バックエンドを分割管理するSaaS型基盤。',
        tech: ['PHP / Laravel', 'React + Vite', 'AWS CDK', 'Terraform'],
      },
      {
        name: '専門職向け業務SaaS',
        desc: '認証基盤・IaC を含めフルスタックで構築。',
        tech: ['Python / FastAPI', 'React 19', 'PostgreSQL', 'AWS Cognito', 'Terraform'],
      },
      {
        name: '利用者向けポータル',
        desc: 'モダンスタックで軽量・高速に構築。',
        tech: ['Go / Echo', 'Svelte 5', 'PostgreSQL', 'GCP (Cloud Run / Cloud SQL)'],
      },
    ],
  },
  {
    icon: '◉',
    category: '業務システム・社内基盤',
    intro: '複雑な業務プロセスを長期運用に耐える設計でシステム化。',
    items: [
      {
        name: '営業・採用管理プラットフォーム（社内基幹）',
        desc: 'データ基盤連携を含む統合管理システム。',
        tech: ['PHP / Laravel', 'React + Inertia.js', 'MySQL', 'AWS (ECS / CDK)', 'Snowflake 連携'],
      },
      {
        name: '社内報告・伝達システム',
        desc: 'コンポーネント駆動で内製。',
        tech: ['PHP / Laravel', 'Next.js', 'Storybook', 'Docker'],
      },
      {
        name: '紹介・マッチングサービス',
        desc: 'Next.js ベースの軽量Web。',
        tech: ['PHP', 'TypeScript', 'Tailwind CSS'],
      },
      {
        name: '求人情報サイト（リニューアル含む）',
        desc: '既存サービスの刷新・機能拡張。',
        tech: ['PHP / Laravel', 'TypeScript', 'Docker'],
      },
    ],
  },
  {
    icon: '◎',
    category: 'API・マイクロサービス・共通基盤',
    intro: '再利用可能なAPI・サーバーレス基盤を内製。',
    items: [
      {
        name: '法定書類 電子伝送API',
        desc: '法定書類を電子伝送する専用API。',
        tech: ['C# / .NET'],
      },
      {
        name: 'URL短縮サービス',
        desc: 'サーバーレス構成のAPIサービス。',
        tech: ['TypeScript', 'AWS (Lambda / DynamoDB / API Gateway)', 'CDK'],
      },
      {
        name: '各種コード解決API群',
        desc: '金融機関・市区町村・郵便番号などのマイクロサービス。',
        tech: ['TypeScript'],
      },
    ],
  },
  {
    icon: '▣',
    category: '業務自動化・データ基盤',
    intro: 'スプレッドシート連携やバッチで業務を自動化・効率化。',
    items: [
      {
        name: '勤怠・経費入力の自動化',
        desc: 'スプレッドシート連携の入力自動化ツール。',
        tech: ['TypeScript (Google Apps Script)'],
      },
      {
        name: 'データ集計基盤',
        desc: '集計バッチ・データ基盤の構築。',
        tech: ['PHP / Laravel', 'Docker'],
      },
      {
        name: 'マスタデータ管理',
        desc: '郵便番号等のデータ管理・API化。',
        tech: ['Python'],
      },
    ],
  },
];

const flowSteps = [
  { no: '01', title: 'ヒアリング・ご相談', body: '課題・目的・ご予算をうかがい、最適な進め方をご提案します。' },
  { no: '02', title: '要件定義・設計', body: 'やるべきことを整理し、長期運用を見据えた設計に落とし込みます。' },
  { no: '03', title: '開発・実装', body: '自社プロダクトで磨いた設計力で、品質を保ちながら構築します。' },
  { no: '04', title: 'テスト・リリース', body: 'テスト自動化とレビューで品質を担保し、安全にリリースします。' },
  { no: '05', title: '運用・保守', body: 'リリース後の改善・保守も継続的にご支援します。' },
];

const plans = [
  {
    icon: '◈',
    title: '請負（プロジェクト受託）',
    body: '要件を固めて一括で開発・納品。新規システム開発やリニューアルに最適です。',
  },
  {
    icon: '◉',
    title: '月額保守・運用',
    body: 'リリース後の改善・保守・パフォーマンス改善を、月額契約で安定して継続します。',
  },
  {
    icon: '◎',
    title: 'スポット相談・技術顧問',
    body: '設計レビューや技術相談など、単発・短期のご支援にも対応します。',
  },
];

const overview = [
  { label: '会社名',    value: 'Promethix合同会社 (Promethix LLC)' },
  { label: '代表社員',  value: '山本 翼' },
  { label: '設立',      value: '2026年7月' },
  { label: '事業内容',  value: 'Webアプリ・業務システムの受託開発' },
  { label: '所在地',    value: '〒150-0044 東京都渋谷区円山町5番3号 MIEUX渋谷ビル8階' },
];

// 対応技術スタック（公開技術のみ。守秘義務に無関係）。技術指定KW（Laravel/Go/FastAPI 受託開発 等）の回収用
const techStack = [
  {
    category: '言語',
    items: ['Go', 'PHP', 'Python', 'TypeScript', 'C# / .NET'],
  },
  {
    category: 'フレームワーク',
    items: ['Laravel', 'Laravel Octane (FrankenPHP)', 'Echo', 'FastAPI', 'React', 'Next.js', 'Vue / Nuxt', 'Svelte', 'Inertia.js'],
  },
  {
    category: 'インフラ・クラウド',
    items: ['GCP (Cloud Run / Cloud SQL)', 'AWS (ECS / Lambda / Aurora / Cognito)', 'Terraform', 'AWS CDK', 'Docker', 'gRPC'],
  },
  {
    category: 'データ基盤・その他',
    items: ['MySQL', 'PostgreSQL', 'DynamoDB', 'BigQuery', 'Snowflake', 'OpenAPI (TypeSpec)', 'Google Apps Script'],
  },
];

// FAQ。本文と FAQPage 構造化データの両方をこの配列1つから生成（単一ソース）。ロングテールKWを回収
const faqs = [
  {
    q: '対応エリアはどこですか？',
    a: '東京都渋谷区円山町（道玄坂）に拠点を置いていますが、打ち合わせはオンライン中心のため、全国どこからのご依頼にも対応できます。',
  },
  {
    q: '費用の目安は？お見積りは無料ですか？',
    a: 'お見積りは無料です。プロジェクトの規模・要件に応じて個別にお見積りし、小さく始めて段階的に広げるスモールスタートにも対応します。',
  },
  {
    q: '契約形態は選べますか？',
    a: '請負（プロジェクト受託）／月額保守・運用／スポット相談・技術顧問の3形態をご用意しています。新規開発から継続的な改善まで、ご状況に合わせてお選びいただけます。',
  },
  {
    q: 'どんな技術スタックに対応していますか？',
    a: 'Go / Echo、PHP / Laravel（Octane・FrankenPHP）、Python / FastAPI、TypeScript、React / Next.js / Vue / Nuxt / Svelte、GCP / AWS、Terraform / CDK などに対応します。要件に最適なスタックを選定します。',
  },
  {
    q: '既存システムの保守やリファクタリングだけでも依頼できますか？',
    a: '可能です。運用・保守、データベースやシステムのパフォーマンス改善、技術的負債の解消・リファクタリングのみのご依頼も承ります。',
  },
  {
    q: '開発にAIをどのように活用していますか？品質は大丈夫ですか？',
    a: '設計レビュー・コード生成・テスト・ドキュメント整備などの工程に生成AIを組み込み、品質と速度を同時に高めています。テスト自動化とコードレビューで品質を担保します。',
  },
  {
    q: '小規模・短期の相談でも対応してもらえますか？',
    a: '対応します。設計レビューや技術相談など、単発・短期のご支援はスポット相談・技術顧問の形でお受けしています。',
  },
  {
    q: 'お問い合わせから開発開始までの流れと期間は？',
    a: 'ヒアリング → 要件定義・設計 → 開発・実装 → テスト・リリース → 運用・保守、という流れで進めます。お問い合わせには最短当日中にご返信します。',
  },
];

// 構造化データ（schema.org JSON-LD）。@id で相互参照し同一エンティティの複数側面として統合させる
const SITE = 'https://promethix-tokyo.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'ProfessionalService'],
      '@id': `${SITE}/#organization`,
      name: 'Promethix合同会社',
      alternateName: 'Promethix LLC',
      legalName: 'Promethix合同会社',
      url: SITE,
      logo: `${SITE}/logo.png`,
      image: `${SITE}/og.png`,
      email: 'contact@promethix-tokyo.com',
      foundingDate: '2026-07',
      founder: { '@type': 'Person', name: '山本 翼' },
      address: {
        '@type': 'PostalAddress',
        postalCode: '150-0044',
        addressRegion: '東京都',
        addressLocality: '渋谷区',
        streetAddress: '円山町5番3号 MIEUX渋谷ビル8階',
        addressCountry: 'JP',
      },
      areaServed: { '@type': 'Country', name: '日本' },
      serviceType: 'Webアプリ・業務システムの受託開発',
      contactPoint: {
        '@type': 'ContactPoint',
        email: 'contact@promethix-tokyo.com',
        contactType: 'customer service',
        availableLanguage: 'Japanese',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: SITE,
      name: 'Promethix LLC',
      inLanguage: 'ja',
      publisher: { '@id': `${SITE}/#organization` },
    },
    {
      '@type': 'FAQPage',
      '@id': `${SITE}/#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Base
  title="渋谷の受託開発会社・Webアプリ／業務システム開発"
  description="渋谷・道玄坂の受託開発会社 Promethix LLC。Webアプリ・業務システム開発から運用保守まで、自社プロダクトで磨いた設計力と生成AIで長く使えるシステムを構築。お見積り無料。"
  jsonLd={jsonLd}
>

  <!-- ── Hero ── -->
  <section id="hero" class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__blob hero__blob--1"></div>
      <div class="hero__blob hero__blob--2"></div>
    </div>
    <div class="container hero__inner">
      <p class="eyebrow fade-up">Software Development — Shibuya, Tokyo</p>
      <h1 class="fade-up" style="transition-delay: 0.07s">
        自社開発で磨かれた<br />
        <span class="gradient-text">技術力をあなたへ。</span>
      </h1>
      <p class="hero__lead fade-up" style="transition-delay: 0.14s">
        多くの自社プロダクトを支える現役エンジニアチームが、<br class="hero__br" />
        最新AIと要件に合わせた設計で、長く使えるシステムを構築します。
      </p>
      <div class="hero__actions fade-up" style="transition-delay: 0.21s">
        <a href="mailto:contact@promethix-tokyo.com" class="btn btn--primary">
          お問い合わせはこちら →
        </a>
        <a href="#services" class="btn btn--ghost">サービスを見る</a>
      </div>
      <dl class="hero__stats fade-up" style="transition-delay: 0.28s">
        <div><dt>開発プロジェクト</dt><dd>30<small>+</small></dd></div>
        <div><dt>継続運用中システム</dt><dd>5<small>+</small></dd></div>
      </dl>
    </div>
  </section>

  <!-- ── About ── -->
  <section id="about" class="section">
    <div class="container">
      <div class="about__header fade-up">
        <p class="eyebrow">About</p>
        <h2>プロダクトを動かすチームが、<br />システムをつくる。</h2>
        <p class="about__lead">
          私たちは、自社プロダクトを企画・開発・運用しているエンジニアチームです。
          日々ユーザーに使われるサービスを改善し続けてきた経験をベースに、
          受託案件でも「長期運用を見据えた設計と品質」を徹底します。
        </p>
      </div>

      <div class="grid grid--3">
        {strengths.map((s, i) => (
          <article class="strength fade-up" style={`--i:${i}`}>
            <span class="strength__no">{s.no}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Services ── -->
  <section id="services" class="section section--soft">
    <div class="container">
      <header class="section__header fade-up">
        <p class="eyebrow">Services</p>
        <h2>提供するサービス</h2>
        <p>プロダクト開発のフェーズや課題に応じて、最適な体制でご支援します。</p>
      </header>

      <div class="grid grid--3">
        {services.map((s, i) => (
          <article class="card service-card fade-up" style={`--i:${i}`}>
            <span class="service-card__icon">{s.icon}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <ul class="service-card__tags">
              {s.tags.map(t => <li>{t}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Works ── -->
  <section id="works" class="section">
    <div class="container">
      <header class="section__header fade-up">
        <p class="eyebrow">Works</p>
        <h2>開発実績</h2>
        <p>自社グループで設計から運用まで手がけた主なシステムです。<br />守秘義務のため、クライアント名・業界は伏せています。</p>
      </header>

      <div class="grid grid--2">
        {works.map((w, i) => (
          <article class="card work-card fade-up" style={`--i:${i % 2}`}>
            <span class="service-card__icon">{w.icon}</span>
            <h3>{w.category}</h3>
            <p class="work-card__intro">{w.intro}</p>
            <ul class="work-card__items">
              {w.items.map((item) => (
                <li class="work-item">
                  <p class="work-item__name">{item.name}</p>
                  <p class="work-item__desc">{item.desc}</p>
                  <ul class="work-item__tags">
                    {item.tech.map((t) => <li>{t}</li>)}
                  </ul>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Tech Stack ── -->
  <section id="tech" class="section section--soft">
    <div class="container">
      <header class="section__header fade-up">
        <p class="eyebrow">Tech Stack</p>
        <h2>対応技術スタック</h2>
        <p>要件に最適な技術を選定します。受託開発で実際に採用している主な技術です。</p>
      </header>

      <div class="grid grid--2">
        {techStack.map((group, i) => (
          <article class="card tech-card fade-up" style={`--i:${i % 2}`}>
            <h3>{group.category}</h3>
            <ul class="service-card__tags tech-card__tags">
              {group.items.map((t) => <li>{t}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Process ── -->
  <section id="process" class="section">
    <div class="container">
      <header class="section__header fade-up">
        <p class="eyebrow">Process</p>
        <h2>進め方とご依頼</h2>
        <p>要件整理から運用まで、無理のない進め方でご一緒します。</p>
      </header>

      <!-- 開発フロー -->
      <ol class="flow">
        {flowSteps.map((s, i) => (
          <li class="flow__step fade-up" style={`--i:${i}`}>
            <span class="flow__no">{s.no}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </li>
        ))}
      </ol>
      <p class="flow__note fade-up">
        ウォーターフォール型の標準フローを基本に、案件の規模やフェーズに応じてスクラム・アジャイル開発も取り入れ、最適な進め方を選びます。
      </p>

      <!-- ご依頼の形 -->
      <h3 class="process__subtitle fade-up">ご依頼の形</h3>
      <div class="grid grid--3">
        {plans.map((p, i) => (
          <article class="card plan-card fade-up" style={`--i:${i}`}>
            <span class="service-card__icon">{p.icon}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>

      <!-- 料金・体制 -->
      <div class="grid grid--2 process__notes">
        <div class="card process-note fade-up">
          <h3>料金</h3>
          <p>プロジェクトの規模・要件に応じて個別にお見積りします（<strong>お見積り無料</strong>）。小さく始めて段階的に広げるスモールスタートにも対応します。</p>
        </div>
        <div class="card process-note fade-up" style="transition-delay: 0.1s">
          <h3>体制</h3>
          <p>プロジェクトマネジメントを兼ねるシニアエンジニア（PM 兼 SE）を中核に、案件の規模に応じてエンジニアを増員する少数精鋭チームです。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section id="faq" class="section section--soft">
    <div class="container">
      <header class="section__header fade-up">
        <p class="eyebrow">FAQ</p>
        <h2>よくあるご質問</h2>
        <p>受託開発のご依頼・費用・契約形態について、よくいただく質問をまとめました。</p>
      </header>

      <dl class="faq fade-up">
        {faqs.map((f) => (
          <div class="faq__item">
